# ══════════════════════════════════════════════════════════════════════════════
# Guard Ring Backend - Environment Configuration
# ══════════════════════════════════════════════════════════════════════════════

# ── Server Configuration ──────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# ── Application URLs ──────────────────────────────────────────────────────────
# Frontend URL (no trailing slash) - supports multiple comma-separated URLs
FRONTEND_URL=http://localhost:5173

# Backend URL (used for webhooks and callbacks)
BACKEND_URL=http://localhost:3001

# ── Security ──────────────────────────────────────────────────────────────────
# CRITICAL: Generate a secure random secret for production
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-use-64-random-bytes

# JWT expiration time (examples: 30d, 7d, 24h, 60m)
JWT_EXPIRATION=30d

# ── Database ──────────────────────────────────────────────────────────────────
# Database directory (defaults to ./data in dev, /tmp/panicring-data in production)
# For persistent storage on Render, set to /data with a mounted Render Disk
DATA_DIR=

# ── PayFast Integration ───────────────────────────────────────────────────────
# Set to 'false' for live payments (requires approved PayFast account)
PAYFAST_SANDBOX=true

# Sandbox test credentials (use as-is for testing)
PAYFAST_MERCHANT_ID=10000100
PAYFAST_MERCHANT_KEY=46f0cd694581a
PAYFAST_PASSPHRASE=jt7NOE43FZPn

# Live PayFast credentials (get from https://www.payfast.co.za/)
# PAYFAST_SANDBOX=false
# PAYFAST_MERCHANT_ID=your_live_merchant_id
# PAYFAST_MERCHANT_KEY=your_live_merchant_key
# PAYFAST_PASSPHRASE=your_live_passphrase

# ── SMS Provider (Twilio) ─────────────────────────────────────────────────────
# Optional: Enable real SMS alerts via Twilio
# Get credentials from https://www.twilio.com/console
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your_auth_token_here
# TWILIO_FROM_NUMBER=+1234567890

# ── Email Configuration ───────────────────────────────────────────────────────
# Optional: Configure email for notifications
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password

# ── Rate Limiting ─────────────────────────────────────────────────────────────
# Maximum authentication attempts per IP per minute
RATE_LIMIT_AUTH=20

# Maximum API requests per IP per minute
RATE_LIMIT_API=100

# ── Logging ───────────────────────────────────────────────────────────────────
# Log level: error, warn, info, debug
LOG_LEVEL=info

# ── Advanced Features ─────────────────────────────────────────────────────────
# Enable/disable specific features
FEATURE_COMMUNITY_MAP=true
FEATURE_LIVE_LOCATION=true
FEATURE_JOURNEY_TRACKING=true
FEATURE_SMS_ALERTS=false

# ── External APIs ─────────────────────────────────────────────────────────────
# Optional: Nominatim reverse geocoding (uses OpenStreetMap by default)
# NOMINATIM_URL=https://nominatim.openstreetmap.org
# NOMINATIM_USER_AGENT=GuardRingApp/2.0
