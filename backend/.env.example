# ─────────────────────────────────────────────────────────────────
# Panic Ring Backend — Environment Variables
# Copy to .env and fill in your values
# ─────────────────────────────────────────────────────────────────

PORT=3001

# REQUIRED: Change this to a long random secret in production
# Generate one: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-this-to-a-long-random-secret-in-production

# Your Netlify frontend URL (no trailing slash)
FRONTEND_URL=https://your-site.netlify.app

# Your backend's own URL (used for PayFast notify_url)
BACKEND_URL=https://your-backend.onrender.com

# ── PayFast ──────────────────────────────────────────────────────
# Set to false for live payments
PAYFAST_SANDBOX=true

# Sandbox test credentials (use as-is for testing)
PAYFAST_MERCHANT_ID=10000100
PAYFAST_MERCHANT_KEY=46f0cd694581a
PAYFAST_PASSPHRASE=jt7NOE43FZPn

# Live credentials — get from https://www.payfast.co.za/registration
# PAYFAST_SANDBOX=false
# PAYFAST_MERCHANT_ID=your_real_merchant_id
# PAYFAST_MERCHANT_KEY=your_real_merchant_key
# PAYFAST_PASSPHRASE=your_real_passphrase

# ── Optional: SMS via Twilio ─────────────────────────────────────
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your_auth_token
# TWILIO_FROM_NUMBER=+1234567890
